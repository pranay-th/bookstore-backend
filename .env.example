# Django core
SECRET_KEY=
DEBUG=True

# Database — Neon PostgreSQL (pooled connection)
# Format: postgresql://<user>:<password>@<pooler-host>/<dbname>?sslmode=require&channel_binding=require
DATABASE_URL=

# CORS — comma-separated allowed origins
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: Analytics microservice base URL
ANALYTICS_SERVICE_URL=
