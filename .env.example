# ============================================================
# Django core
# ============================================================
# development | production
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=
DEBUG=True

# ============================================================
# Database — Neon PostgreSQL (pooled connection) — REQUIRED
# Format: postgresql://<user>:<password>@<pooler-host>/<dbname>?sslmode=require&channel_binding=require
# ============================================================
DATABASE_URL=

# ============================================================
# CORS
# ============================================================
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# JWT — djangorestframework-simplejwt
# ============================================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ============================================================
# Email verification
# Link expiry in minutes (e.g. 1440 = 24 hours)
# FRONTEND_URL is where the user lands after clicking the link
# e.g. https://yourapp.vercel.app
# ============================================================
EMAIL_VERIFICATION_EXPIRY_MINUTES=1440
FRONTEND_URL=http://localhost:3000

# ============================================================
# Login OTP — stored in Redis with TTL
# OTP_LENGTH: 4 or 6
# OTP_EXPIRY_MINUTES: how long before OTP expires
# ============================================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

# ============================================================
# Redis — for OTP storage, Celery broker, WebSocket channel layer
# Format: redis://:<password>@<host>:<port>
# On Render: use the Internal URL from your Key-Value store
# (starts with rediss:// for TLS connections)
# ============================================================
REDIS_URL=

# ============================================================
# Celery — background tasks + scheduled jobs (delivery bots, etc.)
# Broker/result backend default to REDIS_URL when left blank, so you usually
# only need to set CELERY_BROKER_URL if you want a SEPARATE Redis/db for tasks.
# Results are disabled by default to save memory; leave CELERY_RESULT_BACKEND
# blank unless a task needs to return a value you read back.
# ============================================================
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Optional free-tier memory tuning (sensible defaults in settings):
# CELERY_WORKER_MAX_TASKS_PER_CHILD=100
# CELERY_WORKER_MAX_MEMORY_PER_CHILD=150000
# CELERY_TASK_SOFT_TIME_LIMIT=120
# CELERY_TASK_TIME_LIMIT=180

# ============================================================
# SendGrid — via django-anymail
# SENDGRID_API_KEY: your SendGrid API key
# DEFAULT_FROM_EMAIL: must be a verified sender in SendGrid
# ============================================================
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Cron job endpoint secret
# A random secret key that crojob.org sends in X-Cron-Secret header
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
CRON_SECRET_KEY=

# ============================================================
# Analytics microservice base URL (FastAPI)
# Base URL of the bookstore-microservices analytics service.
# Local dev default: http://localhost:8001
# Leave blank to disable analytics proxying (endpoints return 503).
# ============================================================
ANALYTICS_SERVICE_URL=http://localhost:8001
# Per-request timeout (seconds) for calls to the analytics service.
ANALYTICS_SERVICE_TIMEOUT=10

# ============================================================
# Delivery-automation bots (FastAPI microservices)
# These run as separate services and verify the SAME JWT (shared SECRET_KEY).
# The frontend calls them directly; the backend only exposes order data
# (GET /api/orders/{id}/, including book_stock) and accepts status PATCHes the
# tracking bot writes as a shipment advances. URLs are listed here for env
# parity / future server-side calls.
#   Tracking bot  (delivery tracking + ETA):   default http://localhost:8003
#   Delivery bot  (classification/dispatch):   default http://localhost:8004
# ============================================================
TRACKING_SERVICE_URL=http://localhost:8003
DELIVERY_SERVICE_URL=http://localhost:8004


# ============================================================
# Razorpay — Test Mode (UPI payments)
# Dashboard → Settings → API Keys. Use rzp_test_ keys for sandbox.
# RAZORPAY_KEY_SECRET must NEVER be exposed to the frontend.
# ============================================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR
