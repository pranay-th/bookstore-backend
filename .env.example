# ============================================================
# Django core
# ============================================================
# development | production
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=
DEBUG=True

# ============================================================
# Database — Neon PostgreSQL (pooled connection) — REQUIRED
# Format: postgresql://<user>:<password>@<pooler-host>/<dbname>?sslmode=require&channel_binding=require
# ============================================================
DATABASE_URL=

# ============================================================
# CORS
# ============================================================
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================================
# JWT — djangorestframework-simplejwt
# ============================================================
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ============================================================
# Email verification
# Link expiry in minutes (e.g. 1440 = 24 hours)
# FRONTEND_URL is where the user lands after clicking the link
# e.g. https://yourapp.vercel.app
# ============================================================
EMAIL_VERIFICATION_EXPIRY_MINUTES=1440
FRONTEND_URL=http://localhost:3000

# ============================================================
# Login OTP — stored in Redis with TTL
# OTP_LENGTH: 4 or 6
# OTP_EXPIRY_MINUTES: how long before OTP expires
# ============================================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

# ============================================================
# Redis — for OTP storage
# Format: redis://:<password>@<host>:<port>
# ============================================================
REDIS_URL=

# ============================================================
# SendGrid — via django-anymail
# SENDGRID_API_KEY: your SendGrid API key
# DEFAULT_FROM_EMAIL: must be a verified sender in SendGrid
# ============================================================
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Cron job endpoint secret
# A random secret key that crojob.org sends in X-Cron-Secret header
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
CRON_SECRET_KEY=

# ============================================================
# Analytics microservice base URL (FastAPI)
# Base URL of the bookstore-microservices analytics service.
# Local dev default: http://localhost:8001
# Leave blank to disable analytics proxying (endpoints return 503).
# ============================================================
ANALYTICS_SERVICE_URL=http://localhost:8001
# Per-request timeout (seconds) for calls to the analytics service.
ANALYTICS_SERVICE_TIMEOUT=10
